generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Audiobook {
  id               String        @id @default(cuid())
  title            String
  author           String
  imageUrl         String
  youtubeId        String
  descriptionShort String        @db.Text
  descriptionLong  String        @db.Text
  duration         String
  genre            String
  language         String
  year             Int
  isPublished      Boolean       @default(false)
  category         ItemCategory  @default(BOOK)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum ItemCategory {
  BOOK
  MUSIC
}
