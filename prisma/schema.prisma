generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String         @id @default(cuid())
  email     String         @unique
  password  String
  role      Role           @default(USER)
  createdAt DateTime       @default(now())
  progress  UserProgress[]
  library   UserLibrary[]
  ratings   Rating[]
}

model Audiobook {
  id               String           @id @default(cuid())
  title            String
  author           String
  imageUrl         String
  youtubeId        String?          @unique
  descriptionShort String           @db.Text
  descriptionLong  String           @db.Text
  duration         String
  genre            String
  language         String
  year             Int
  status           AudiobookStatus  @default(Draft)
  isFeatured       Boolean          @default(false)
  relatedIds       String[]         @default([])
  categoryId       String?
  subcategoryId    String?
  sourceUrl        String?
  channelId        String?
  rightsHolder     String?
  permissionStatus PermissionStatus @default(unknown)
  chapters         Json?
  lastCheckedAt    DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  progress         UserProgress[]
  library          UserLibrary[]
  ratings          Rating[]
  category         Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory      Subcategory?     @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  audiobookId String
  seconds     Float
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audiobook Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)

  @@unique([userId, audiobookId])
}

model UserLibrary {
  id          String    @id @default(cuid())
  userId      String
  audiobookId String
  addedAt     DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audiobook Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)

  @@unique([userId, audiobookId])
}

model Category {
  id            String        @id @default(cuid())
  nameUk        String        @unique
  nameEn        String        @default("")
  subcategories Subcategory[]
  audiobooks    Audiobook[]
  createdAt     DateTime      @default(now())
}

model Subcategory {
  id         String      @id @default(cuid())
  nameUk     String
  nameEn     String      @default("")
  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  genres     Genre[]
  audiobooks Audiobook[]
  createdAt  DateTime    @default(now())

  @@unique([nameUk, categoryId])
}

model Genre {
  id            String       @id @default(cuid())
  nameUk        String       @unique
  nameEn        String       @default("")
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}

model LandingConfig {
  id      String @id @default(cuid())
  locale  String @unique
  content Json
}

model Rating {
  id          String    @id @default(cuid())
  userId      String
  audiobookId String
  stars       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audiobook Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)

  @@unique([userId, audiobookId])
}

model IngestionLog {
  id        String   @id @default(cuid())
  videoId   String
  bookId    String?
  action    String
  message   String?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum AudiobookStatus {
  Draft
  Review
  Published
  Unavailable
}

enum PermissionStatus {
  unknown
  allowed
  pending
  denied
}
