generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String         @id @default(cuid())
  email     String         @unique
  password  String
  role      Role           @default(USER)
  createdAt DateTime       @default(now())
  progress  UserProgress[]
  library   UserLibrary[]
}

model Audiobook {
  id               String         @id @default(cuid())
  title            String
  author           String
  imageUrl         String
  youtubeId        String
  descriptionShort String         @db.Text
  descriptionLong  String         @db.Text
  duration         String
  genre            String
  language         String
  year             Int
  isPublished      Boolean        @default(false)
  isFeatured       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  progress         UserProgress[]
  library          UserLibrary[]
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  audiobookId String
  seconds     Float
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audiobook Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)

  @@unique([userId, audiobookId])
}

model UserLibrary {
  id          String    @id @default(cuid())
  userId      String
  audiobookId String
  addedAt     DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audiobook Audiobook @relation(fields: [audiobookId], references: [id], onDelete: Cascade)

  @@unique([userId, audiobookId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  genres    Genre[]
  createdAt DateTime @default(now())
}

model Genre {
  id         String    @id @default(cuid())
  name       String    @unique
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

model LandingConfig {
  id      String @id @default(cuid())
  locale  String @unique
  content Json
}

enum Role {
  USER
  ADMIN
}
