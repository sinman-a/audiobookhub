# PostgreSQL connection (Neon pooled)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# PostgreSQL direct connection (for migrations)
DIRECT_URL="postgresql://user:password@direct-host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-random-secret-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"
